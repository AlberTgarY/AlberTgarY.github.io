---
layout: default
---
<div class="post">
  <header class="post-header">
    <h1 class="post-title">
      {% if site.title == 'blank' %}
        <span class="font-weight-bold">{{ site.first_name }}</span> {{ site.middle_name }}
        {{ site.last_name }}
      {% else %}
        {{ site.title }}
      {% endif %}
    </h1>
    <p class="desc">{{ page.subtitle }}</p>
  </header>

  <article>
    {% if page.profile %}
      <div class="profile float-{% if page.profile.align == 'left' %}left{% else %}right{% endif %}">
        {% if page.profile.image %}
          {% if page.profile.image_circular %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded-circle' %}
          {% else %}
            {% assign profile_image_class = 'img-fluid z-depth-1 rounded' %}
          {% endif %}
          {% assign profile_image_1 = page.profile.image | prepend: '/assets/img/' | relative_url %}
          {% if page.profile.image2 %}
            {% assign profile_image_2 = page.profile.image2 | prepend: '/assets/img/' | relative_url %}
          {% endif %}
          <div class="profile-photo-switcher">
            <style>
              .profile-photo-switcher {
                position: relative;
                display: inline-block;
                width: 100%;
              }
              .profile-photo-switcher #profile-photo {
                display: block;
                width: 100%;
              }
              .profile-photo-arrow {
                position: absolute;
                bottom: 0.5rem;
                z-index: 2;
                border: none;
                width: 2.2rem;
                height: 2.2rem;
                border-radius: 50%;
                background: rgba(0, 0, 0, 0.45);
                color: #fff;
                font-size: 1.1rem;
                line-height: 1;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                opacity: 0.7;
                transition:
                  opacity 0.2s ease,
                  background 0.2s ease;
              }
              .profile-photo-arrow:hover {
                opacity: 1;
                background: rgba(0, 0, 0, 0.7);
              }
              .profile-photo-arrow-left {
                left: 0.5rem;
              }
              .profile-photo-arrow-right {
                right: 0.5rem;
              }
            </style>
            <img
              id="profile-photo"
              class="{{ profile_image_class }}"
              src="{{ profile_image_1 }}"
              alt="{{ page.profile.image }}"
              loading="eager"
            >
            {% if profile_image_2 %}
              <button type="button" id="profile-photo-prev" class="profile-photo-arrow profile-photo-arrow-left" aria-label="Previous photo">
                &#8592;
              </button>
              <button type="button" id="profile-photo-next" class="profile-photo-arrow profile-photo-arrow-right" aria-label="Next photo">
                &#8594;
              </button>
              <script>
                (function () {
                  var photos = ['{{ profile_image_1 }}', '{{ profile_image_2 }}'];
                  var idx = 0;
                  var img = document.getElementById('profile-photo');
                  function show(next) {
                    idx = (idx + next + photos.length) % photos.length;
                    img.src = photos[idx];
                  }
                  var prev = document.getElementById('profile-photo-prev');
                  var nxt = document.getElementById('profile-photo-next');
                  if (prev)
                    prev.addEventListener('click', function () {
                      show(-1);
                    });
                  if (nxt)
                    nxt.addEventListener('click', function () {
                      show(1);
                    });
                })();
              </script>
            {% endif %}
          </div>
        {% endif %}
        {% if page.profile.more_info %}
          <div class="more-info">{{ page.profile.more_info }}</div>
        {% endif %}
      </div>
    {% endif %}

    <div class="clearfix">{{ content }}</div>

    <!-- News -->
    {% if page.announcements and page.announcements.enabled %}
      <h2>
        <a href="{{ '/news/' | relative_url }}" style="color: inherit">news</a>
      </h2>
      {% include news.liquid limit=true %}
    {% endif %}

    <!-- Latest posts -->
    {% if page.latest_posts and page.latest_posts.enabled %}
      <h2>
        <a href="{{ '/blog/' | relative_url }}" style="color: inherit">latest posts</a>
      </h2>
      {% include latest_posts.liquid %}
    {% endif %}

    <!-- Selected papers -->
    {% if page.selected_papers %}
      <h2>
        <a href="{{ '/publications/' | relative_url }}" style="color: inherit">selected publications</a>
      </h2>
      {% include selected_papers.liquid %}
    {% endif %}

    {% if site.newsletter and site.newsletter.enabled and site.footer_fixed %}
      {% include newsletter.liquid center=true %}
    {% endif %}
  </article>
</div>
